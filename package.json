{
  "name": "infernodrift-afterburn",
  "version": "6.0.0",
  "private": true,
  "type": "module",
  "description": "InfernoDrift: Afterburn, a deterministic volcanic arcade racer with authoritative multiplayer.",
  "scripts": {
    "dev": "vite --config client/vite.config.ts --host 127.0.0.1",
    "dev:web": "vite --config client/vite.config.ts --host 127.0.0.1",
    "dev:server": "tsx apps/afterburn-server/src/index.ts",
    "build": "npm run typecheck && npm run build:web",
    "build:web": "vite build --config client/vite.config.ts",
    "build:server": "tsc -p apps/afterburn-server/tsconfig.json",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "format": "prettier --check .",
    "icons": "node scripts/generate-icons.mjs",
    "audit:firebase-public": "node scripts/audit-firebase-public-data.mjs",
    "cleanup:firebase-public": "node scripts/cleanup-firebase-public-data.mjs",
    "test": "node --import tsx --test tests/afterburn-*.test.ts",
    "test:multiplayer": "node --import tsx --test tests/afterburn-multiplayer.test.ts",
    "smoke:afterburn": "node scripts/run-afterburn-smoke.mjs",
    "smoke": "node scripts/run-with-server.mjs smoke_games.mjs",
    "smoke:account-xp": "node scripts/run-with-server.mjs smoke_account_xp_safety.mjs",
    "smoke:account-xp:target": "node smoke_account_xp_safety.mjs",
    "smoke:firebase": "node scripts/run-with-server.mjs smoke_firebase_offline.mjs",
    "smoke:firebase-live": "node scripts/run-with-server.mjs smoke_firebase_live.mjs",
    "smoke:online-local": "node scripts/run-with-server.mjs smoke_online_local.mjs",
    "test:e2e": "node scripts/run-with-server.mjs smoke_devmode.mjs && node scripts/run-with-server.mjs smoke_mobile.mjs",
    "worker:check": "wrangler deploy --dry-run",
    "worker:types": "wrangler types --check",
    "deploy:worker": "wrangler deploy"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "firebase": "^12.16.0",
    "firebase-admin": "^13.10.0",
    "jose": "^6.2.3",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "three": "^0.184.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "ws": "^8.18.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "http-server": "^14.1.1",
    "playwright": "^1.57.0",
    "prettier": "^3.7.4",
    "tsx": "^4.22.0",
    "wrangler": "^4.90.1"
  }
}
