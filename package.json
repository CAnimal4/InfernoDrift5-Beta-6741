{
  "name": "infernodrift4",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:web": "npm --workspace apps/web run dev",
    "dev:server": "npm --workspace apps/server run dev",
    "build": "npm run build:packages && npm run build:web && npm run build:server",
    "build:packages": "npm --workspace packages/protocol run build && npm --workspace packages/game-core run build",
    "build:web": "npm --workspace apps/web run build",
    "build:server": "npm --workspace apps/server run build",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "tsc -b --pretty false",
    "format": "prettier --check .",
    "smoke": "node tests/smoke.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.7",
    "typescript": "^5.9.3",
    "tsx": "^4.21.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "three": "^0.182.0",
    "zod": "^4.2.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.181.0",
    "@types/ws": "^8.18.1",
    "prettier": "^3.7.4",
    "vitest": "^4.0.15"
  }
}
