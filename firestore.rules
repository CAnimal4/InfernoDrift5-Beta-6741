rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function safeUsername(value) {
      return value is string
        && value.size() >= 3
        && value.size() <= 20
        && value.matches('^[A-Za-z0-9][A-Za-z0-9 _-]{1,18}[A-Za-z0-9]$');
    }

    function safeProfileKeys() {
      return request.resource.data.keys().hasOnly([
        'uid',
        'username',
        'usernameLower',
        'displayName',
        'isGuest',
        'badges',
        'age',
        'createdAt',
        'lastSeenAt',
        'stats',
        'settings',
        'cosmetics',
        'loadouts',
        'progress'
      ]);
    }

    function safeLobbyCode(value) {
      return value is string
        && value.size() >= 4
        && value.size() <= 8
        && value.matches('^[A-Z0-9]+$');
    }

    match /users/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid)
        && safeProfileKeys()
        && request.resource.data.uid == request.auth.uid
        && safeUsername(request.resource.data.username)
        && request.resource.data.badges is list
        && !('admin' in request.resource.data)
        && !('role' in request.resource.data)
        && !('moderator' in request.resource.data);
      allow delete: if false;
    }

    match /usernames/{usernameLower} {
      allow read: if true;
      allow create: if signedIn()
        && !exists(/databases/$(database)/documents/usernames/$(usernameLower))
        && request.resource.data.uid == request.auth.uid
        && safeUsername(request.resource.data.username)
        && request.resource.data.usernameLower == usernameLower
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'usernameLower',
          'createdAt'
        ]);
      allow update, delete: if false;
    }

    match /progress/{uid} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'payload',
          'campaign',
          'unlocks',
          'cosmetics',
          'stats',
          'settings',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /leaderboards/{mode}/scores/{scoreId} {
      allow read: if true;
      allow create, update: if signedIn()
        && scoreId == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.score is number
        && request.resource.data.score >= 0
        && request.resource.data.score <= 1000000
        && request.resource.data.verified == false
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'badges',
          'score',
          'mode',
          'carClass',
          'runId',
          'clientVersion',
          'verified',
          'createdAt'
        ]);
      allow delete: if false;
    }

    match /chatRooms/{roomId}/messages/{messageId} {
      allow read: if signedIn();
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() > 0
        && request.resource.data.text.size() <= 300
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'badges',
          'text',
          'channel',
          'type',
          'toUid',
          'toUsername',
          'roomInvite',
          'moderationFlags',
          'createdAt',
          'createdAtClient'
        ]);
      allow update, delete: if false;
    }

    match /lobbies/{code} {
      allow read: if signedIn();
      allow create: if signedIn()
        && safeLobbyCode(code)
        && request.resource.data.code == code
        && request.resource.data.hostUid == request.auth.uid
        && request.resource.data.players is list
        && request.resource.data.players.size() >= 1
        && request.resource.data.players.size() <= 8
        && request.resource.data.keys().hasOnly([
          'code',
          'hostUid',
          'hostUsername',
          'mode',
          'playlist',
          'teamSize',
          'size',
          'botFill',
          'private',
          'live',
          'backendMode',
          'players',
          'createdAt',
          'updatedAt'
        ]);
      allow update: if signedIn()
        && safeLobbyCode(code)
        && request.resource.data.code == resource.data.code
        && request.resource.data.hostUid == resource.data.hostUid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'players',
          'updatedAt'
        ])
        && request.resource.data.players is list
        && request.resource.data.players.size() >= resource.data.players.size()
        && request.resource.data.players.size() <= 8
        && request.resource.data.keys().hasOnly([
          'code',
          'hostUid',
          'hostUsername',
          'mode',
          'playlist',
          'teamSize',
          'size',
          'botFill',
          'private',
          'live',
          'backendMode',
          'players',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /feedback/{feedbackId} {
      allow read: if false;
      allow create: if signedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2500
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'message',
          'feedbackType',
          'diagnostics',
          'clientVersion',
          'userAgent',
          'replyEmail',
          'status',
          'createdAt'
        ]);
      allow update, delete: if false;
    }

    match /friendRequests/{requestId} {
      allow read: if signedIn()
        && (resource.data.fromUid == request.auth.uid || resource.data.toUid == request.auth.uid);
      allow create: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.keys().hasOnly([
          'fromUid',
          'fromUsername',
          'toUid',
          'toUsername',
          'status',
          'createdAt',
          'updatedAt'
        ]);
      allow update: if signedIn()
        && resource.data.toUid == request.auth.uid
        && request.resource.data.fromUid == resource.data.fromUid
        && request.resource.data.toUid == resource.data.toUid
        && request.resource.data.fromUsername == resource.data.fromUsername
        && request.resource.data.toUsername == resource.data.toUsername
        && request.resource.data.status in ['accepted', 'declined']
        && request.resource.data.keys().hasOnly([
          'fromUid',
          'fromUsername',
          'toUid',
          'toUsername',
          'status',
          'createdAt',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /friends/{uid}/items/{friendUid} {
      allow read: if isOwner(uid);
      allow create, update: if signedIn()
        && (request.auth.uid == uid || request.auth.uid == friendUid)
        && request.resource.data.uid == friendUid
        && request.resource.data.status == 'accepted'
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'createdAt',
          'status'
        ]);
      allow delete: if isOwner(uid);
    }

    match /diagnostics/{diagnosticId} {
      allow read: if signedIn()
        && diagnosticId == request.auth.uid;
      allow create, update: if signedIn()
        && diagnosticId == request.auth.uid
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          'uid',
          'username',
          'backendMode',
          'at',
          'client'
        ]);
      allow delete: if false;
    }
  }
}
