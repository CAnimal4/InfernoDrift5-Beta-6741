{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "infernodrift4-online",
  "main": "apps/worker/src/index.js",
  "compatibility_date": "2026-05-01",
  "observability": {
    "enabled": true,
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "INFERNO_ROOM",
        "class_name": "InfernoRoom",
      },
    ],
  },
  "migrations": [
    {
      "tag": "v1",
      "new_classes": ["InfernoRoom"],
    },
  ],
}
