# Local Node backend defaults. Production online now uses Firebase online-lite;
# Node/Worker URLs are legacy development and fallback references only.
PORT=8787
ALLOWED_ORIGINS=https://canimal4.github.io,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,http://localhost:4173,http://127.0.0.1:4173
DATA_DIR=./data

# Legacy Replit SQL / Postgres persistence. Do not use Replit dev links or paid
# publish as production unless the project owner explicitly changes direction.
# DATABASE_URL=

# Optional local feedback notification config. Production values should be
# configured in Cloudflare/Resend, never committed as client-visible secrets.
FEEDBACK_FROM=InfernoDrift4 <feedback@infernodrift.local>
FEEDBACK_TO=clarkbythebay@gmail.com,clark.alden@lbusd.org

# Firebase web config is public and belongs in firebase-config.js or a runtime
# window.INFERNO_FIREBASE_CONFIG object. Never commit Admin SDK/service-account
# keys or private tokens.

# Optional local overrides. Uncomment only when needed.
# INFERNO_BACKEND_MODE=firebase
# VITE_SERVER_URL=wss://infernodrift4-online.clarkbythebay.workers.dev/ws
# RESEND_API_KEY=
# TURNSTILE_SECRET_KEY=
