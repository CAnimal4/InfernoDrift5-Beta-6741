# Local Node backend defaults.
PORT=8787
ALLOWED_ORIGINS=https://canimal4.github.io,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,http://localhost:4173,http://127.0.0.1:4173
DATA_DIR=./data

# Replit SQL / Postgres persistence. Configure this in Replit Secrets or the
# Replit SQL integration; never commit the real value.
# DATABASE_URL=

# Optional local feedback notification config. Production values should be
# configured in Cloudflare/Resend, never committed as client-visible secrets.
FEEDBACK_FROM=InfernoDrift4 <feedback@infernodrift.local>
FEEDBACK_TO=clarkbythebay@gmail.com,clark.alden@lbusd.org

# Optional local overrides. Uncomment only when needed.
# VITE_SERVER_URL=wss://infernodrift4-online.clarkbythebay.workers.dev/ws
# RESEND_API_KEY=
# TURNSTILE_SECRET_KEY=
