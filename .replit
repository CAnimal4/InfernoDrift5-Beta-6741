run = "npm run dev:server"
entrypoint = "apps/server/src/index.js"

[env]
NODE_ENV = "production"
ALLOWED_ORIGINS = "https://canimal4.github.io,http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000,http://localhost:4173,http://127.0.0.1:4173"

[deployment]
run = ["sh", "-c", "npm run dev:server"]
